<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Movie Review App</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background-color: #1a1a1a;
            min-height: 100vh;
            padding: 20px;
            transition: background-color 0.3s ease;
        }

        .container {
            max-width: 900px;
            margin: 0 auto;
        }

        h1 {
            text-align: center;
            color: #fff;
            margin-bottom: 30px;
            font-size: 2.5em;
            text-shadow: 2px 2px 4px rgba(0,0,0,0.5);
            transition: all 0.3s ease;
        }

        .controls-section {
            background-color: rgba(255,255,255,0.1);
            padding: 20px;
            border-radius: 10px;
            margin-bottom: 30px;
            backdrop-filter: blur(10px);
        }

        .controls-title {
            color: #fff;
            margin-bottom: 15px;
            font-size: 1.2em;
            font-weight: bold;
        }

        .color-controls {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 15px;
        }

        .control-group {
            display: flex;
            flex-direction: column;
            gap: 8px;
        }

        .control-group label {
            color: #fff;
            font-size: 0.9em;
            font-weight: 500;
        }

        .control-group input[type="color"] {
            width: 100%;
            height: 45px;
            border: none;
            border-radius: 5px;
            cursor: pointer;
        }

        .form-section {
            background: linear-gradient(135deg, rgba(255,255,255,0.1), rgba(255,255,255,0.05));
            padding: 30px;
            border-radius: 10px;
            margin-bottom: 30px;
            backdrop-filter: blur(10px);
            border: 1px solid rgba(255,255,255,0.1);
        }

        .form-group {
            margin-bottom: 20px;
        }

        .form-group label {
            display: block;
            margin-bottom: 8px;
            color: #fff;
            font-weight: 500;
            font-size: 1em;
            transition: color 0.3s ease;
        }

        .form-group input,
        .form-group select {
            width: 100%;
            padding: 12px;
            border: 2px solid rgba(255,255,255,0.2);
            border-radius: 5px;
            font-size: 1em;
            background-color: rgba(255,255,255,0.1);
            color: #fff;
            transition: all 0.3s ease;
        }

        .form-group input::placeholder,
        .form-group select option {
            color: rgba(255,255,255,0.6);
        }

        .form-group input:focus,
        .form-group select:focus {
            outline: none;
            border-color: rgba(255,255,255,0.5);
            background-color: rgba(255,255,255,0.15);
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(0,0,0,0.3);
        }

        .button-group {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
            gap: 10px;
        }

        button {
            padding: 12px 20px;
            font-size: 1em;
            border: none;
            border-radius: 5px;
            cursor: pointer;
            font-weight: bold;
            transition: all 0.3s ease;
            text-transform: uppercase;
        }

        .btn-submit {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
        }

        .btn-submit:hover {
            transform: translateY(-3px);
            box-shadow: 0 10px 20px rgba(102, 126, 234, 0.4);
        }

        .btn-clear {
            background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
            color: white;
        }

        .btn-clear:hover {
            transform: translateY(-3px);
            box-shadow: 0 10px 20px rgba(245, 87, 108, 0.4);
        }

        .reviews-section {
            margin-top: 30px;
        }

        .reviews-title {
            color: #fff;
            font-size: 1.8em;
            margin-bottom: 20px;
            text-align: center;
        }

        .review-card {
            background: linear-gradient(135deg, rgba(255,255,255,0.1), rgba(255,255,255,0.05));
            padding: 20px;
            border-radius: 8px;
            margin-bottom: 15px;
            backdrop-filter: blur(10px);
            border-left: 5px solid #667eea;
            transition: all 0.3s ease;
        }

        .review-card:hover {
            transform: translateX(5px);
            box-shadow: 0 5px 20px rgba(0,0,0,0.3);
        }

        .review-movie-name {
            font-size: 1.3em;
            font-weight: bold;
            margin-bottom: 10px;
        }

        .review-detail {
            margin: 8px 0;
            font-size: 0.95em;
            opacity: 0.9;
        }

        .review-detail strong {
            margin-right: 10px;
        }

        .rating-stars {
            color: #ffc107;
            font-size: 1.2em;
            margin-top: 10px;
        }

        .no-reviews {
            text-align: center;
            color: rgba(255,255,255,0.5);
            padding: 40px;
            font-size: 1.1em;
        }

        @media (max-width: 600px) {
            h1 {
                font-size: 1.8em;
            }

            .color-controls {
                grid-template-columns: 1fr;
            }

            .form-section {
                padding: 15px;
            }
        }
    </style>
</head>
<body>
    <div class="container">
        <h1 id="headline">🎬 Movie Review App</h1>

        <!-- Color Controls Section -->
        <div class="controls-section">
            <div class="controls-title">🎨 Customize Your App</div>
            <div class="color-controls">
                <div class="control-group">
                    <label for="bgColorPicker">Background Color:</label>
                    <input type="color" id="bgColorPicker" value="#1a1a1a">
                </div>
                <div class="control-group">
                    <label for="textColorPicker">Text Color:</label>
                    <input type="color" id="textColorPicker" value="#ffffff">
                </div>
                <div class="control-group">
                    <label for="fieldColorPicker">Input Field Color:</label>
                    <input type="color" id="fieldColorPicker" value="#2a2a2a">
                </div>
                <div class="control-group">
                    <label for="headlineColorPicker">Headline Color:</label>
                    <input type="color" id="headlineColorPicker" value="#ffffff">
                </div>
            </div>
        </div>

        <!-- Form Section -->
        <div class="form-section">
            <form id="movieForm">
                <div class="form-group">
                    <label for="movieName">🎥 Movie Name:</label>
                    <input type="text" id="movieName" placeholder="Enter movie name..." required>
                </div>

                <div class="form-group">
                    <label for="releaseDate">📅 Release Date:</label>
                    <input type="date" id="releaseDate" required>
                </div>

                <div class="form-group">
                    <label for="movieCategory">🎭 Movie Category:</label>
                    <select id="movieCategory" required>
                        <option value="">Select a category...</option>
                        <option value="Action">Action</option>
                        <option value="Comedy">Comedy</option>
                        <option value="Drama">Drama</option>
                        <option value="Horror">Horror</option>
                        <option value="Sci-Fi">Sci-Fi</option>
                        <option value="Romance">Romance</option>
                        <option value="Thriller">Thriller</option>
                        <option value="Animation">Animation</option>
                        <option value="Documentary">Documentary</option>
                        <option value="Fantasy">Fantasy</option>
                    </select>
                </div>

                <div class="form-group">
                    <label for="movieRating">⭐ Rating (1-10):</label>
                    <input type="number" id="movieRating" min="1" max="10" step="0.1" placeholder="Enter rating..." required>
                </div>

                <div class="button-group">
                    <button type="submit" class="btn-submit">Add Review</button>
                    <button type="reset" class="btn-clear">Clear Form</button>
                </div>
            </form>
        </div>

        <!-- Reviews Section -->
        <div class="reviews-section">
            <h2 class="reviews-title">📽️ Movie Reviews</h2>
            <div id="reviewsContainer"></div>
        </div>
    </div>

    <script>
        // Initialize reviews array from localStorage
        let reviews = JSON.parse(localStorage.getItem('movieReviews')) || [];

        // Color Control Elements
        const bgColorPicker = document.getElementById('bgColorPicker');
        const textColorPicker = document.getElementById('textColorPicker');
        const fieldColorPicker = document.getElementById('fieldColorPicker');
        const headlineColorPicker = document.getElementById('headlineColorPicker');

        // Form Elements
        const movieForm = document.getElementById('movieForm');
        const movieNameInput = document.getElementById('movieName');
        const releaseDateInput = document.getElementById('releaseDate');
        const movieCategorySelect = document.getElementById('movieCategory');
        const movieRatingInput = document.getElementById('movieRating');
        const reviewsContainer = document.getElementById('reviewsContainer');
        const headline = document.getElementById('headline');

        // Load saved colors
        function loadColors() {
            const savedColors = JSON.parse(localStorage.getItem('appColors')) || {};
            if (savedColors.bgColor) {
                bgColorPicker.value = savedColors.bgColor;
                applyBackgroundColor(savedColors.bgColor);
            }
            if (savedColors.textColor) {
                textColorPicker.value = savedColors.textColor;
                applyTextColor(savedColors.textColor);
            }
            if (savedColors.fieldColor) {
                fieldColorPicker.value = savedColors.fieldColor;
                applyFieldColor(savedColors.fieldColor);
            }
            if (savedColors.headlineColor) {
                headlineColorPicker.value = savedColors.headlineColor;
                applyHeadlineColor(savedColors.headlineColor);
            }
        }

        // Apply Background Color
        function applyBackgroundColor(color) {
            document.body.style.backgroundColor = color;
            saveColors();
        }

        // Apply Text Color
        function applyTextColor(color) {
            const root = document.documentElement;
            root.style.setProperty('--text-color', color);
            document.querySelectorAll('label, .control-group label, .reviews-title, .no-reviews').forEach(el => {
                el.style.color = color;
            });
            saveColors();
        }

        // Apply Field Color
        function applyFieldColor(color) {
            document.querySelectorAll('input, select').forEach(el => {
                el.style.backgroundColor = color;
            });
            saveColors();
        }

        // Apply Headline Color
        function applyHeadlineColor(color) {
            headline.style.color = color;
            saveColors();
        }

        // Save colors to localStorage
        function saveColors() {
            const colors = {
                bgColor: bgColorPicker.value,
                textColor: textColorPicker.value,
                fieldColor: fieldColorPicker.value,
                headlineColor: headlineColorPicker.value
            };
            localStorage.setItem('appColors', JSON.stringify(colors));
        }

        // Color picker event listeners
        bgColorPicker.addEventListener('input', (e) => applyBackgroundColor(e.target.value));
        textColorPicker.addEventListener('input', (e) => applyTextColor(e.target.value));
        fieldColorPicker.addEventListener('input', (e) => applyFieldColor(e.target.value));
        headlineColorPicker.addEventListener('input', (e) => applyHeadlineColor(e.target.value));

        // Add Review
        movieForm.addEventListener('submit', (e) => {
            e.preventDefault();

            const review = {
                id: Date.now(),
                movieName: movieNameInput.value,
                releaseDate: releaseDateInput.value,
                movieCategory: movieCategorySelect.value,
                movieRating: parseFloat(movieRatingInput.value)
            };

            reviews.push(review);
            localStorage.setItem('movieReviews', JSON.stringify(reviews));

            movieForm.reset();
            displayReviews();
        });

        // Display Reviews
        function displayReviews() {
            if (reviews.length === 0) {
                reviewsContainer.innerHTML = '<div class="no-reviews">No reviews yet. Add your first movie review!</div>';
                return;
            }

            reviewsContainer.innerHTML = reviews.map(review => `
                <div class="review-card">
                    <div class="review-movie-name">${review.movieName}</div>
                    <div class="review-detail">
                        <strong>📅 Release Date:</strong> ${new Date(review.releaseDate).toLocaleDateString()}
                    </div>
                    <div class="review-detail">
                        <strong>🎭 Category:</strong> ${review.movieCategory}
                    </div>
                    <div class="rating-stars">
                        <strong>⭐ Rating:</strong> ${review.movieRating}/10 ${'★'.repeat(Math.round(review.movieRating))}
                    </div>
                </div>
            `).join('');
        }

        // Initialize
        loadColors();
        displayReviews();
    </script>
</body>
</html>
